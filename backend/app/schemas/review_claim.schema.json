{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "review_claim.schema.json",
  "title": "ReviewClaim",
  "version": "review-claim-1.0",
  "type": "object",
  "properties": {
    "claim_id": {"type": "string"},
    "target_document_id": {"type": "string"},
    "text": {"type": "string"},
    "location": {
      "type": "object",
      "properties": {
        "page": {"type": ["integer", "null"]},
        "section": {"type": ["string", "null"]}
      }
    },
    "normalized_statement": {
      "type": "object",
      "properties": {
        "statement_type": {"enum": ["THRESHOLD", "DEADLINE", "OBLIGATION", "PROHIBITION", "PERMISSION"]},
        "subject": {"type": ["string", "null"]},
        "action": {"type": ["string", "null"]},
        "modality": {"enum": ["MUST", "MUST_NOT", "MAY", "SHOULD", null]},
        "value": {"type": ["number", "null"]},
        "unit": {"type": ["string", "null"]},
        "scope": {"type": ["string", "null"]},
        "exceptions": {"type": "array", "items": {"type": "string"}},
        "effective_context": {"type": ["string", "null"]},
        "source_span": {
          "type": "object",
          "properties": {
            "page": {"type": ["integer", "null"]},
            "section": {"type": ["string", "null"]},
            "text": {"type": ["string", "null"]}
          }
        }
      }
    }
  },
  "required": ["claim_id", "target_document_id", "text"]
}
