{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "claim_assessment.schema.json",
  "title": "ClaimAssessment",
  "version": "claim-assessment-1.0",
  "type": "object",
  "properties": {
    "claim_id": {"type": "string"},
    "claim_text": {"type": "string"},
    "location": {"type": "object"},
    "normalized_statement": {"type": "object"},
    "status": {"enum": ["COMPLIANT", "NON_COMPLIANT", "PARTIALLY_COMPLIANT",
                         "OUTDATED_REFERENCE", "MISSING_EVIDENCE", "AMBIGUOUS",
                         "NEEDS_HUMAN_REVIEW"]},
    "document_value": {"type": ["string", "null"]},
    "regulatory_value": {"type": ["string", "null"]},
    "explanation": {"type": "string"},
    "evidence": {"type": "array", "items": {"$ref": "evidence_reference.schema.json"}},
    "suggested_revision": {"type": ["string", "null"]},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "requires_human_review": {"type": "boolean"}
  },
  "required": ["claim_id", "claim_text", "status", "explanation", "evidence"]
}
